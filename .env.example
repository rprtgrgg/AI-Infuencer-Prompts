# Nova Linh — Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to GitHub

# ── Required ──────────────────────────────────────
# Claude API (anthropic.com)
CLAUDE_API_KEY=sk-ant-your-key-here

# GitHub Personal Access Token (repo scope)
GITHUB_TOKEN=ghp_your-token-here
GITHUB_REPO=yourusername/nova-linh-website
GITHUB_BRANCH=main

# Freepik API (freepik.com/api)
FREEPIK_API_KEY=your-freepik-key-here

# ── Optional ──────────────────────────────────────
# X (Twitter) Bearer Token (developer.twitter.com)
# If not set, workflow uses fallback trend data
X_BEARER_TOKEN=your-x-bearer-token-here

# Higgsfield API (higgsfield.ai)
HIGGSFIELD_API_KEY=your-higgsfield-key-here
